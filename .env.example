# Copiar para .env e ajustar antes de subir em produção.
# No Railway, configure essas variáveis no painel Variables (não use .env real).

# Acesso ao painel admin (HTTP Basic)
MEDIDOR_ADMIN_USER=admin
MEDIDOR_ADMIN_PASSWORD=troque-esta-senha

# Banco — Railway injeta DATABASE_URL automaticamente ao anexar Postgres.
# Localmente, sem esta variável, o app cai no SQLite em data/medidor.db.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db

# Cookies HTTPS-only (set 1 em produção atrás de TLS)
MEDIDOR_COOKIE_SECURE=1

# Playwright — em ambiente custom, aponta para onde Chromium foi instalado.
# Na imagem oficial mcr.microsoft.com/playwright/python, NÃO precisa setar.
# PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
